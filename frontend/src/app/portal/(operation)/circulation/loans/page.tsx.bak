'use client';

import { useState, useRef, useEffect } from 'react';
import Cookies from 'js-cookie';
import {
    Search, Plus, User, Book, Trash2,
    FileText, Eye, BookOpen, Clock, X, ChevronDown, Check,
    AlertCircle, DollarSign, Calendar, MapPin, Phone, Mail, Cake
} from 'lucide-react';

// --- UI COMPONENTS ---
interface ButtonProps extends React.ButtonHTMLAttributes<HTMLButtonElement> {
    children: React.ReactNode;
    variant?: 'primary' | 'outline' | 'ghost' | 'secondary' | 'danger' | 'success';
    size?: 'default' | 'sm' | 'icon';
    className?: string;
}

const Button = ({ children, variant = 'primary', size = 'default', className = '', ...props }: ButtonProps) => {
    const base = "inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none disabled:opacity-50 disabled:pointer-events-none";
    const variants: Record<string, string> = {
        primary: "bg-blue-600 text-white hover:bg-blue-700 shadow-sm",
        outline: "border border-slate-200 bg-white hover:bg-slate-100 text-slate-900",
        ghost: "hover:bg-slate-100 hover:text-slate-900 text-slate-500",
        secondary: "bg-slate-100 text-slate-900 hover:bg-slate-200",
        danger: "bg-red-50 text-red-600 hover:bg-red-100",
        success: "bg-green-600 text-white hover:bg-green-700 shadow-sm",
    };
    const sizes: Record<string, string> = {
        default: "h-10 py-2 px-4",
        sm: "h-9 px-3 rounded-md",
        icon: "h-10 w-10",
    };
    return <button className={`${base} ${variants[variant]} ${sizes[size]} ${className}`} {...props}>{children}</button>;
};

interface InputProps extends React.InputHTMLAttributes<HTMLInputElement> {
    className?: string;
    label?: string; // Optional label for cleaner JSX
}

const Input = ({ className = '', ...props }: InputProps) => (
    <input className={`flex h-10 w-full rounded-md border border-slate-200 bg-white px-3 py-2 text-sm ring-offset-white file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-slate-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 disabled:cursor-not-allowed disabled:opacity-50 disabled:bg-slate-100 disabled:text-slate-500 ${className}`} {...props} />
);

interface BadgeProps {
    children: React.ReactNode;
    variant?: 'default' | 'outline' | 'success' | 'danger' | 'warning';
    className?: string;
}

const Badge = ({ children, variant = 'default', className = '' }: BadgeProps) => {
    const styles = variant === 'outline' ? "border border-slate-200 text-slate-900" :
        variant === 'success' ? "bg-green-100 text-green-700 border-green-200 border" :
            variant === 'danger' ? "bg-red-100 text-red-700 border-red-200 border" :
                variant === 'warning' ? "bg-orange-100 text-orange-700 border-orange-200 border" :
                    "bg-blue-100 text-blue-700 border-blue-200 border";
    return <div className={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none ${styles} ${className}`}>{children}</div>;
};

// --- API INTERFACES ---
interface ApiReader {
    _id: string;
    fullName: string;
    email: string;
    dateOfBirth: string;
    address: string;
    totalDebt: number;
    readerTypeId: {
        _id: string;
        readerTypeName: string;
    } | string;
}

interface ApiBook {
    _id: string;
    name: string;
    author: string;
    category: string;
}

interface ApiBookCopy {
    _id: string;
    status: number; // 1 = Available, 0 = Borrowed
    bookId: ApiBook | string;
}

interface ApiLoan {
    _id: string;
    borrowDate: string;
    readerId: ApiReader | string;
}

interface ApiLoanDetail {
    _id: string;
    loanId: string;
    copyId: ApiBookCopy | string;
    returnDate?: string;
    fineAmount: number;
}

interface LoanDetail {
    bookCode: string;
    title: string;
    category: string;
    status: string;
    returnDate?: string;
    fine?: number;
    note?: string;
    copyId: string; // Added for return logic
    detailId: string; // Added for return logic
}

// --- INTERFACES ---
interface Loan {
    id: string;
    readerId: string;
    readerName: string;
    date: string;
    dueDate: string;
    returnDate?: string;
    status: 'active' | 'overdue' | 'returned';
    count: number;
    details?: LoanDetail[]; // Added to store details
}

interface BorrowRow {
    id: number;
    code: string;
    title: string;
    author: string;
    category: string;
    copyId?: string; // Store real copy ID
}

interface ReaderInfo {
    id: string;
    name: string;
    class: string;
    email: string;
    dob: string;
    phone: string;
    address: string;
}

interface ReturnPreviewData {
    loanInfo: Loan;
    books: LoanDetail[];
    overdueDays: number;
    estimatedFine: number;
}

// --- COMPONENT: COMBOBOX ---
interface ComboboxProps {
    options: string[];
    value: string;
    onChange: (value: string) => void;
    placeholder?: string;
    className?: string;
    disabled?: boolean;
}

const Combobox = ({ options, value, onChange, placeholder, className, disabled }: ComboboxProps) => {
    const [isOpen, setIsOpen] = useState(false);
    const [inputValue, setInputValue] = useState(value);
    const [dropdownPosition, setDropdownPosition] = useState({ top: 0, left: 0, width: 0 });
    const wrapperRef = useRef<HTMLDivElement>(null);
    const inputRef = useRef<HTMLInputElement>(null);

    useEffect(() => { setInputValue(value); }, [value]);

    useEffect(() => {
        function handleClickOutside(event: MouseEvent) {
            if (wrapperRef.current && !wrapperRef.current.contains(event.target as Node)) {
                setIsOpen(false);
                if (inputValue !== value) onChange(inputValue);
            }
        }
        document.addEventListener("mousedown", handleClickOutside);
        return () => document.removeEventListener("mousedown", handleClickOutside);
    }, [inputValue, value, onChange]);

    useEffect(() => {
        if (isOpen && inputRef.current) {
            const rect = inputRef.current.getBoundingClientRect();
            setDropdownPosition({
                top: rect.bottom + window.scrollY,
                left: rect.left + window.scrollX,
                width: rect.width
            });
        }
    }, [isOpen]);

    const filteredOptions = options.filter(opt => opt.toLowerCase().includes(inputValue.toLowerCase()));

    return (
        <div className={`relative ${className}`} ref={wrapperRef}>
            <div className="relative">
                <input
                    ref={inputRef}
                    type="text"
                    className={`w-full border border-slate-200 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white ${disabled ? 'bg-slate-50 text-slate-500' : ''}`}
                    placeholder={placeholder}
                    value={inputValue}
                    onChange={(e) => { setInputValue(e.target.value); setIsOpen(true); onChange(e.target.value); }}
                    onFocus={() => !disabled && setIsOpen(true)}
                    disabled={disabled}
                />
                <div className="absolute right-2 top-2.5 pointer-events-none text-slate-400"><ChevronDown className="w-4 h-4" /></div>
            </div>
            {isOpen && !disabled && filteredOptions.length > 0 && (
                <div
                    className="fixed z-[9999] bg-white border border-slate-200 rounded-md shadow-xl max-h-60 overflow-auto py-1"
                    style={{
                        top: `${dropdownPosition.top + 4}px`,
                        left: `${dropdownPosition.left}px`,
                        width: `${dropdownPosition.width}px`
                    }}
                >
                    {filteredOptions.map((opt, index) => (
                        <li key={index} className="px-3 py-2 text-sm hover:bg-blue-50 cursor-pointer flex justify-between items-center group list-none"
                            onMouseDown={(e) => {
                                e.preventDefault();
                                setInputValue(opt);
                                onChange(opt);
                                setIsOpen(false);
                            }}>
                            <span className="text-slate-700">{opt}</span>
                            {opt === value && <Check className="w-4 h-4 text-blue-600" />}
                        </li>
                    ))}
                </div>
            )}
        </div>
    );
};

// --- MAIN PAGE COMPONENT ---

export default function CirculationPage() {
    const [activeTab, setActiveTab] = useState<'borrow' | 'return'>('borrow');

    // Modal States
    const [isLoanModalOpen, setIsLoanModalOpen] = useState(false);
    const [isReturnModalOpen, setIsReturnModalOpen] = useState(false);
    const [isDetailModalOpen, setIsDetailModalOpen] = useState(false);
    const [selectedLoan, setSelectedLoan] = useState<Loan | null>(null);

    // State Lập phiếu
    const [borrowReaderId, setBorrowReaderId] = useState("");
    const [borrowReaderInfo, setBorrowReaderInfo] = useState<ReaderInfo | null>(null); // State chứa full info độc giả
    const [borrowRows, setBorrowRows] = useState<BorrowRow[]>([{ id: 1, code: "", title: "", author: "", category: "" }]);

    // State Xử lý Trả sách
    const [returnQuery, setReturnQuery] = useState("");
    const [returnPreview, setReturnPreview] = useState<ReturnPreviewData | null>(null);

    // --- LOGIC ---

    const handleReaderChange = (id: string) => {
        setBorrowReaderId(id);
        const reader = mockReaders.find(r => r.id.toLowerCase() === id.toLowerCase());

        // Cập nhật state thông tin chi tiết
        if (reader) {
            setBorrowReaderInfo(reader);
        } else {
            setBorrowReaderInfo(null);
        }
    }

    const activeLoansList = allLoans.filter(l => l.status === 'active' || l.status === 'overdue');
    const returnedLoansList = allLoans.filter(l => l.status === 'returned');

    const handleViewDetail = (loan: Loan) => {
        setSelectedLoan(loan);
        setIsDetailModalOpen(true);
    };

    // --- LOGIC TRẢ SÁCH ---
    const handleCheckReturn = () => {
        const loan = allLoans.find(l => l.id.toLowerCase() === returnQuery.toLowerCase());

        if (loan) {
            const today = new Date();
            const due = new Date(loan.dueDate);
            const diffTime = Math.abs(today.getTime() - due.getTime());
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            const isOverdue = today > due;
            const overdueDays = isOverdue ? diffDays : 0;
            const finePerDay = 5000;
            const estimatedFine = overdueDays * finePerDay;

            setReturnPreview({
                loanInfo: loan,
                books: mockLoanDetails[loan.id] || [],
                overdueDays: overdueDays,
                estimatedFine: estimatedFine
            });
        } else {
            setReturnPreview(null);
            alert("Không tìm thấy mã phiếu mượn này!");
        }
    };

    const handleConfirmReturn = () => {
        alert("Đã xử lý trả sách thành công!");
        setIsReturnModalOpen(false);
        setReturnPreview(null);
        setReturnQuery("");
    };

    // --- LOGIC FORM LẬP PHIẾU ---
    const addRow = () => {
        if (borrowRows.length >= 5) return;
        setBorrowRows([...borrowRows, { id: Date.now(), code: "", title: "", author: "", category: "" }]);
    };

    const removeRow = (id: number) => {
        if (borrowRows.length === 1) {
            setBorrowRows([{ id: Date.now(), code: "", title: "", author: "", category: "" }]);
        } else {
            setBorrowRows(borrowRows.filter(r => r.id !== id));
        }
    };

    const updateRow = (id: number, field: keyof BorrowRow, value: string) => {
        const newRows = borrowRows.map(row => {
            if (row.id === id) {
                const updatedRow = { ...row, [field]: value };
                if (field === 'code') {
                    const book = libraryInventory.find(b => b.code.toLowerCase() === value.toLowerCase());
                    if (book) {
                        updatedRow.title = book.title;
                        updatedRow.author = book.author;
                        updatedRow.category = book.category;
                    }
                } else if (field === 'title') {
                    const booksWithTitle = libraryInventory.filter(b => b.title.toLowerCase() === value.toLowerCase());
                    if (booksWithTitle.length > 0) {
                        const info = booksWithTitle[0];
                        updatedRow.author = info.author;
                        updatedRow.category = info.category;
                        const availableCopies = booksWithTitle.filter(b => b.status === 'Sẵn sàng');
                        if (availableCopies.length === 1) updatedRow.code = availableCopies[0].code;
                        else if (row.title !== value) updatedRow.code = "";
                    }
                }
                return updatedRow;
            }
            return row;
        });
        setBorrowRows(newRows);
    };

    const optionsCodes = libraryInventory.filter(b => b.status === 'Sẵn sàng').map(b => b.code);
    const optionsTitles = [...new Set(libraryInventory.map(b => b.title))];
    const optionsAuthors = [...new Set(libraryInventory.map(b => b.author))];
    const optionsCategories = [...new Set(libraryInventory.map(b => b.category))];
    const optionsReaderIds = mockReaders.map(r => r.id);

    return (
        <div className="min-h-screen bg-slate-50/50 p-6 font-sans text-slate-900 space-y-8">
            {/* HEADER */}
            <div>
                <h1 className="text-3xl font-bold text-slate-900">Quản lý Lưu thông</h1>
                <p className="text-slate-500 mt-1">Theo dõi Mượn - Trả & Lịch sử giao dịch</p>
            </div>

            {/* TABS */}
            <div className="w-full space-y-6">
                <div className="flex p-1 bg-white border rounded-lg w-fit shadow-sm">
                    <button onClick={() => setActiveTab('borrow')} className={`px-6 py-2.5 text-sm font-medium rounded-md transition-all flex items-center gap-2 ${activeTab === 'borrow' ? 'bg-blue-50 text-blue-700 shadow-sm' : 'text-slate-500 hover:text-slate-900'}`}>
                        <BookOpen className="w-4 h-4" /> Danh sách Đang mượn
                    </button>
                    <button onClick={() => setActiveTab('return')} className={`px-6 py-2.5 text-sm font-medium rounded-md transition-all flex items-center gap-2 ${activeTab === 'return' ? 'bg-green-50 text-green-700 shadow-sm' : 'text-slate-500 hover:text-slate-900'}`}>
                        <Clock className="w-4 h-4" /> Lịch sử Đã trả
                    </button>
                </div>

                <div className="bg-white rounded-xl border shadow-sm min-h-[500px]">
                    {/* TAB CONTENT */}
                    {activeTab === 'borrow' && (
                        <div className="p-6 space-y-6 animate-in fade-in">
                            <div className="flex justify-between items-center">
                                <div className="relative w-96">
                                    <Search className="absolute left-3 top-2.5 h-4 w-4 text-slate-400" />
                                    <Input placeholder="Tìm mã phiếu, độc giả..." className="pl-9" />
                                </div>
                                <Button onClick={() => {
                                    setBorrowReaderId("");
                                    setBorrowReaderInfo(null);
                                    setBorrowRows([{ id: Date.now(), code: "", title: "", author: "", category: "" }]);
                                    setIsLoanModalOpen(true);
                                }}>
                                    <Plus className="w-4 h-4 mr-2" /> Lập Phiếu Mượn
                                </Button>
                            </div>
                            <LoanTable data={activeLoansList} onViewDetail={handleViewDetail} />
                        </div>
                    )}

                    {activeTab === 'return' && (
                        <div className="p-6 space-y-6 animate-in fade-in">
                            <div className="flex justify-between items-center">
                                <div className="relative w-96">
                                    <Search className="absolute left-3 top-2.5 h-4 w-4 text-slate-400" />
                                    <Input placeholder="Tìm lịch sử phiếu trả..." className="pl-9" />
                                </div>
                                <Button variant="success" onClick={() => setIsReturnModalOpen(true)} className="shadow-md">
                                    <Check className="w-4 h-4 mr-2" /> Nhận Trả Sách
                                </Button>
                            </div>
                            <LoanTable data={returnedLoansList} onViewDetail={handleViewDetail} isHistory />
                        </div>
                    )}
                </div>
            </div>

            {/* === MODAL 1: LẬP PHIẾU MƯỢN (ĐÃ UPDATE THÊM FIELD) === */}
            {isLoanModalOpen && (
                <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
                    <div className="bg-white rounded-xl shadow-2xl w-full max-w-6xl max-h-[95vh] flex flex-col overflow-hidden animate-in zoom-in-95">
                        <div className="px-6 py-4 border-b flex justify-between items-center bg-slate-50">
                            <div><h2 className="text-lg font-bold text-slate-800">Lập Phiếu Mượn Mới</h2></div>
                            <button onClick={() => setIsLoanModalOpen(false)}><X className="w-6 h-6 text-slate-400 hover:text-slate-600" /></button>
                        </div>
                        <div className="flex-1 overflow-y-auto p-6 space-y-6 bg-slate-50/30">
                            {/* SECTION THÔNG TIN ĐỘC GIẢ */}
                            <div className="bg-white p-5 rounded-lg border shadow-sm">
                                <div className="flex items-center gap-2 mb-4 text-blue-700 font-semibold text-sm uppercase">
                                    <User className="w-4 h-4" /> Thông tin Độc giả
                                </div>
                                {/* Layout Grid 3 Cột */}
                                <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                                    {/* Cột 1 */}
                                    <div className="space-y-1">
                                        <label className="text-sm font-medium">Mã độc giả <span className="text-red-500">*</span></label>
                                        <Combobox value={borrowReaderId} onChange={handleReaderChange} options={optionsReaderIds} placeholder="Nhập mã..." />
                                    </div>
                                    <div className="space-y-1">
                                        <label className="text-sm font-medium">Họ tên độc giả</label>
                                        <Input disabled value={borrowReaderInfo?.name || ""} placeholder="..." className="bg-slate-50" />
                                    </div>
                                    <div className="space-y-1">
                                        <label className="text-sm font-medium flex items-center gap-1"><Mail className="w-3 h-3" /> Email</label>
                                        <Input disabled value={borrowReaderInfo?.email || ""} placeholder="..." className="bg-slate-50" />
                                    </div>

                                    {/* Cột 2 (Hàng dưới) */}
                                    <div className="space-y-1">
                                        <label className="text-sm font-medium flex items-center gap-1"><Phone className="w-3 h-3" /> Số điện thoại</label>
                                        <Input disabled value={borrowReaderInfo?.phone || ""} placeholder="..." className="bg-slate-50" />
                                    </div>
                                    <div className="space-y-1">
                                        <label className="text-sm font-medium flex items-center gap-1"><Cake className="w-3 h-3" /> Ngày sinh</label>
                                        <Input disabled value={borrowReaderInfo?.dob || ""} placeholder="..." className="bg-slate-50" />
                                    </div>
                                    <div className="space-y-1">
                                        <label className="text-sm font-medium flex items-center gap-1"><MapPin className="w-3 h-3" /> Địa chỉ</label>
                                        <Input disabled value={borrowReaderInfo?.address || ""} placeholder="..." className="bg-slate-50" />
                                    </div>
                                </div>
                            </div>

                            <div className="bg-white p-5 rounded-lg border shadow-sm min-h-[300px]">
                                <div className="flex justify-between items-center mb-4">
                                    <div className="flex items-center gap-2 text-blue-700 font-semibold text-sm uppercase"><Book className="w-4 h-4" /> Chi tiết Sách ({borrowRows.length}/5)</div>
                                    <ExpectedDueDate />
                                </div>
                                <div className="border rounded-lg overflow-hidden pb-4">
                                    <table className="w-full text-sm text-left">
                                        <thead className="bg-slate-100 text-slate-600">
                                            <tr>
                                                <th className="px-3 py-2 w-10 text-center">#</th>
                                                <th className="px-3 py-2 w-48">Mã Sách</th>
                                                <th className="px-3 py-2">Tên Sách</th>
                                                <th className="px-3 py-2 w-48">Tác giả</th>
                                                <th className="px-3 py-2 w-40">Thể loại</th>
                                                <th className="px-3 py-2 w-10"></th>
                                            </tr>
                                        </thead>
                                        <tbody className="divide-y divide-slate-100">
                                            {borrowRows.map((row, index) => (
                                                <tr key={row.id} className="bg-white">
                                                    <td className="px-3 py-2 text-center text-slate-400">{index + 1}</td>
                                                    <td className="px-3 py-2"><Combobox value={row.code} onChange={(val) => updateRow(row.id, 'code', val)} options={optionsCodes} placeholder="Mã..." className="text-blue-600 font-medium" /></td>
                                                    <td className="px-3 py-2"><Combobox value={row.title} onChange={(val) => updateRow(row.id, 'title', val)} options={optionsTitles} placeholder="Tên sách..." /></td>
                                                    <td className="px-3 py-2"><Combobox value={row.author} onChange={(val) => updateRow(row.id, 'author', val)} options={optionsAuthors} placeholder="Tác giả..." /></td>
                                                    <td className="px-3 py-2"><Combobox value={row.category} onChange={(val) => updateRow(row.id, 'category', val)} options={optionsCategories} placeholder="Thể loại..." /></td>
                                                    <td className="px-3 py-2 text-center"><button onClick={() => removeRow(row.id)} className="text-slate-300 hover:text-red-500"><Trash2 className="w-4 h-4" /></button></td>
                                                </tr>
                                            ))}
                                        </tbody>
                                    </table>
                                </div>
                                <div className="mt-3"><Button variant="outline" size="sm" onClick={addRow} className="border-dashed w-full text-slate-500 hover:text-blue-600"><Plus className="w-4 h-4 mr-2" /> Thêm dòng</Button></div>
                            </div>
                        </div>
                        <div className="px-6 py-4 border-t bg-slate-50 flex justify-end gap-3">
                            <Button variant="outline" onClick={() => setIsLoanModalOpen(false)}>Hủy</Button>
                            <Button>Lưu Phiếu Mượn</Button>
                        </div>
                    </div>
                </div>
            )}

            {/* === MODAL 2: XỬ LÝ TRẢ SÁCH === */}
            {isReturnModalOpen && (
                <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
                    <div className="bg-white rounded-xl shadow-2xl w-full max-w-4xl flex flex-col overflow-hidden animate-in zoom-in-95">
                        <div className="px-6 py-4 border-b flex justify-between items-center bg-green-50">
                            <div>
                                <h2 className="text-lg font-bold text-green-800 flex items-center gap-2">
                                    <Check className="w-5 h-5" /> Nhận Trả Sách
                                </h2>
                            </div>
                            <button onClick={() => { setIsReturnModalOpen(false); setReturnPreview(null); setReturnQuery(""); }}><X className="w-6 h-6 text-slate-400 hover:text-slate-600" /></button>
                        </div>

                        <div className="p-6 bg-slate-50/50 flex-1 overflow-y-auto">
                            {/* Step 1: Search */}
                            <div className="flex gap-3 mb-6">
                                <div className="relative flex-1">
                                    <Search className="absolute left-3 top-2.5 h-4 w-4 text-slate-400" />
                                    <Input
                                        placeholder="Nhập hoặc quét mã phiếu mượn (VD: PM002)..."
                                        className="pl-9 h-11 text-lg"
                                        value={returnQuery}
                                        onChange={(e) => setReturnQuery(e.target.value)}
                                        onKeyDown={(e) => e.key === 'Enter' && handleCheckReturn()}
                                    />
                                </div>
                                <Button size="default" className="h-11 px-6" onClick={handleCheckReturn}>Kiểm tra</Button>
                            </div>

                            {/* Step 2: Preview Details */}
                            {returnPreview && (
                                <div className="space-y-6 animate-in fade-in slide-in-from-bottom-4">
                                    {/* Info Cards */}
                                    <div className="grid grid-cols-2 gap-4">
                                        <div className="bg-white p-4 rounded-lg border shadow-sm">
                                            <div className="text-xs font-semibold text-slate-400 uppercase mb-2">Thông tin Độc giả</div>
                                            <div className="font-medium text-lg text-slate-900">{returnPreview.loanInfo.readerName}</div>
                                            <div className="text-slate-500 text-sm">Mã: {returnPreview.loanInfo.readerId}</div>
                                        </div>
                                        <div className="bg-white p-4 rounded-lg border shadow-sm">
                                            <div className="text-xs font-semibold text-slate-400 uppercase mb-2">Trạng thái Phiếu</div>
                                            <div className="flex items-center gap-2">
                                                <span className="text-sm">Hạn trả: </span>
                                                <span className="font-bold">{returnPreview.loanInfo.dueDate}</span>
                                            </div>
                                            {returnPreview.overdueDays > 0 ? (
                                                <div className="mt-1 flex items-center text-red-600 font-bold text-sm">
                                                    <AlertCircle className="w-4 h-4 mr-1" /> Quá hạn {returnPreview.overdueDays} ngày
                                                </div>
                                            ) : (
                                                <div className="mt-1 text-green-600 font-medium text-sm">Đúng hạn</div>
                                            )}
                                        </div>
                                    </div>

                                    {/* Books List */}
                                    <div className="bg-white rounded-lg border shadow-sm overflow-hidden">
                                        <div className="px-4 py-3 bg-slate-100 border-b font-semibold text-sm flex justify-between">
                                            <span>Sách đang mượn ({returnPreview.books.length})</span>
                                            <span className="text-slate-500 font-normal">Tự động chọn tất cả</span>
                                        </div>
                                        <table className="w-full text-sm text-left">
                                            <thead className="bg-slate-50 text-slate-500">
                                                <tr>
                                                    <th className="px-4 py-2 w-10"><input type="checkbox" checked readOnly className="rounded" /></th>
                                                    <th className="px-4 py-2">Mã sách</th>
                                                    <th className="px-4 py-2">Tên sách</th>
                                                    <th className="px-4 py-2">Ghi chú (Tình trạng)</th>
                                                </tr>
                                            </thead>
                                            <tbody className="divide-y divide-slate-100">
                                                {returnPreview.books.map((book, idx) => (
                                                    <tr key={idx}>
                                                        <td className="px-4 py-3"><input type="checkbox" checked readOnly className="rounded text-blue-600" /></td>
                                                        <td className="px-4 py-3 font-mono text-slate-600">{book.bookCode}</td>
                                                        <td className="px-4 py-3 font-medium">{book.title}</td>
                                                        <td className="px-4 py-3">
                                                            <input type="text" placeholder="VD: Rách bìa..." className="border-b border-transparent hover:border-slate-300 focus:border-blue-500 focus:outline-none w-full text-sm py-1 bg-transparent" />
                                                        </td>
                                                    </tr>
                                                ))}
                                            </tbody>
                                        </table>
                                    </div>

                                    {/* Fine Calculation */}
                                    <div className="bg-red-50 border border-red-100 rounded-lg p-4 flex justify-between items-center">
                                        <div>
                                            <div className="font-bold text-red-800 flex items-center gap-2">
                                                <DollarSign className="w-5 h-5" /> TỔNG TIỀN PHẠT DỰ KIẾN
                                            </div>
                                            <div className="text-sm text-red-600 mt-1">
                                                (5.000đ x {returnPreview.overdueDays} ngày quá hạn)
                                            </div>
                                        </div>
                                        <div className="text-2xl font-bold text-red-700">
                                            {returnPreview.estimatedFine.toLocaleString('vi-VN')} đ
                                        </div>
                                    </div>
                                </div>
                            )}
                        </div>

                        {returnPreview && (
                            <div className="px-6 py-4 border-t bg-slate-50 flex justify-end gap-3">
                                <Button variant="outline" onClick={() => { setReturnPreview(null); setReturnQuery(""); }}>Hủy bỏ</Button>
                                <Button variant="primary" onClick={handleConfirmReturn} className="px-8">
                                    Xác nhận Trả & Thu tiền
                                </Button>
                            </div>
                        )}
                    </div>
                </div>
            )}

            {/* === MODAL 3: XEM CHI TIẾT === */}
            {isDetailModalOpen && selectedLoan && (
                <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
                    <div className="bg-white rounded-lg shadow-xl w-full max-w-3xl overflow-hidden animate-in zoom-in-95">
                        <div className="px-6 py-4 border-b flex justify-between items-center bg-slate-50">
                            <div>
                                <h2 className="text-lg font-bold flex items-center gap-2">
                                    <FileText className="w-5 h-5 text-blue-600" />
                                    Chi tiết Phiếu mượn: <span className="font-mono text-slate-700">{selectedLoan.id}</span>
                                </h2>
                            </div>
                            <button onClick={() => setIsDetailModalOpen(false)}><X className="w-5 h-5 text-slate-400 hover:text-slate-600" /></button>
                        </div>

                        <div className="p-6 space-y-6">
                            {/* Detail Header Info */}
                            <div className="grid grid-cols-3 gap-4">
                                <div className="col-span-1 space-y-1">
                                    <p className="text-xs text-slate-500 uppercase font-semibold">Độc giả</p>
                                    <p className="font-medium text-slate-900">{selectedLoan.readerName}</p>
                                    <p className="text-sm text-slate-500">Mã: {selectedLoan.readerId}</p>
                                </div>
                                <div className="col-span-1 space-y-1">
                                    <p className="text-xs text-slate-500 uppercase font-semibold">Thời gian</p>
                                    <div className="text-sm flex items-center gap-2"><Calendar className="w-3 h-3" /> Mượn: {selectedLoan.date}</div>
                                    <div className={`text-sm flex items-center gap-2 font-medium ${selectedLoan.status === 'overdue' ? 'text-red-600' : 'text-slate-700'}`}>
                                        <AlertCircle className="w-3 h-3" /> Hạn: {selectedLoan.dueDate}
                                    </div>
                                </div>
                                <div className="col-span-1 bg-slate-50 p-3 rounded border border-slate-100">
                                    <p className="text-xs text-slate-500 uppercase font-semibold mb-1">Tổng quan tài chính</p>
                                    <div className="flex justify-between text-sm mb-1">
                                        <span>Trạng thái:</span>
                                        {selectedLoan.status === 'returned' ? <span className="text-green-600 font-bold">Đã hoàn tất</span> : <span className="text-blue-600 font-bold">Đang mở</span>}
                                    </div>
                                    <div className="flex justify-between text-sm font-bold border-t pt-1 mt-1">
                                        <span>Phạt quá hạn:</span>
                                        <span className="text-red-600">
                                            {selectedLoan.status === 'overdue' ? '35.000 đ' : '0 đ'}
                                        </span>
                                    </div>
                                </div>
                            </div>

                            {/* Detail Table */}
                            <div className="border rounded-md overflow-hidden">
                                <table className="w-full text-sm text-left">
                                    <thead className="bg-slate-100 text-slate-700 font-semibold">
                                        <tr>
                                            <th className="px-4 py-2">Mã sách</th>
                                            <th className="px-4 py-2">Tên sách</th>
                                            <th className="px-4 py-2">Trạng thái</th>
                                            <th className="px-4 py-2">Ghi chú</th>
                                            {selectedLoan.status === 'returned' && <th className="px-4 py-2 text-right">Ngày trả</th>}
                                        </tr>
                                    </thead>
                                    <tbody className="divide-y divide-slate-100">
                                        {mockLoanDetails[selectedLoan.id] ? mockLoanDetails[selectedLoan.id].map((book, i) => (
                                            <tr key={i}>
                                                <td className="px-4 py-2 font-mono text-slate-600">{book.bookCode}</td>
                                                <td className="px-4 py-2 font-medium">{book.title}</td>
                                                <td className="px-4 py-2">
                                                    <span className={`text-xs px-2 py-1 rounded border ${book.status === 'Đã trả' ? 'bg-green-50 text-green-700 border-green-200' : 'bg-blue-50 text-blue-700 border-blue-200'}`}>
                                                        {book.status}
                                                    </span>
                                                </td>
                                                <td className="px-4 py-2 text-slate-500 italic">{book.note || "-"}</td>
                                                {selectedLoan.status === 'returned' && (
                                                    <td className="px-4 py-2 text-right font-mono text-xs">{book.returnDate}</td>
                                                )}
                                            </tr>
                                        )) : (
                                            <tr><td colSpan={5} className="p-4 text-center text-slate-400">Không có dữ liệu chi tiết</td></tr>
                                        )}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div className="px-6 py-4 bg-slate-50 text-right">
                            <Button variant="outline" onClick={() => setIsDetailModalOpen(false)}>Đóng</Button>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
}

// Helper Component for Clean Table
const LoanTable = ({ data, onViewDetail, isHistory = false }: { data: Loan[], onViewDetail: (l: Loan) => void, isHistory?: boolean }) => (
    <div className="rounded-md border overflow-hidden">
        <table className="w-full text-sm text-left">
            <thead className="bg-slate-50 text-slate-500 font-medium">
                <tr>
                    <th className="px-4 py-3">Mã Phiếu</th>
                    <th className="px-4 py-3">Độc Giả</th>
                    <th className="px-4 py-3">Ngày Mượn</th>
                    <th className="px-4 py-3">{isHistory ? 'Ngày Trả' : 'Hạn Trả'}</th>
                    <th className="px-4 py-3">Trạng thái</th>
                    <th className="px-4 py-3 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody className="divide-y divide-slate-100">
                {data.map((loan) => (
                    <tr key={loan.id} className="hover:bg-slate-50">
                        <td className={`px-4 py-3 font-medium ${isHistory ? 'text-green-600' : 'text-blue-600'}`}>{loan.id}</td>
                        <td className="px-4 py-3 font-medium">{loan.readerName}</td>
                        <td className="px-4 py-3">{loan.date}</td>
                        <td className={`px-4 py-3 ${loan.status === 'overdue' ? 'text-red-600 font-bold' : ''}`}>{isHistory ? loan.returnDate : loan.dueDate}</td>
                        <td className="px-4 py-3">
                            {loan.status === 'overdue' ? <Badge variant="danger">Quá hạn</Badge> :
                                loan.status === 'returned' ? <Badge variant="success">Đã trả</Badge> : <Badge>Đang mượn</Badge>}
                        </td>
                        <td className="px-4 py-3 text-right">
                            <Button variant="ghost" size="sm" onClick={() => onViewDetail(loan)}>
                                <Eye className="w-4 h-4 mr-2" /> {isHistory ? 'Xem lại' : 'Chi tiết'}
                            </Button>
                        </td>
                    </tr>
                ))}
            </tbody>
        </table>
    </div>
);

const ExpectedDueDate = () => {
    const [dueDate] = useState(() => new Date(Date.now() + 4 * 24 * 60 * 60 * 1000).toLocaleDateString('vi-VN'));
    return <span className="text-xs text-slate-500">Hạn trả dự kiến: <b>{dueDate}</b></span>;
};